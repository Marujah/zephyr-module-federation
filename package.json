{
  "name": "my-zephyr-app-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -k -n react-build,react-serve,vue-build,vue-serve,host \"pnpm dev:react:build\" \"pnpm dev:react:serve\" \"pnpm dev:vue:build\" \"pnpm dev:vue:serve\" \"pnpm dev:host\"",
    "dev:react:build": "pnpm --dir react-remote build:watch",
    "dev:react:serve": "pnpm --dir react-remote preview:mf",
    "dev:vue:build": "pnpm --dir vue-remote build:watch",
    "dev:vue:serve": "pnpm --dir vue-remote preview:mf",
    "dev:host": "pnpm --dir orchestrator dev",
    "build": "pnpm --filter react-remote build",
    "build:host": "pnpm --filter orchestrator build",
    "build:all": "pnpm -r build",
    "preview": "pnpm --dir orchestrator preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
