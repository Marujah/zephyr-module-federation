{
  "name": "vue-remote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "tsc && vite build",
    "build:zephyr": "ENABLE_ZEPHYR=1 tsc && vite build",
    "build:watch": "vite build --watch",
    "preview:mf": "sh -c 'while [ ! -f dist/assets/remoteEntry.js ]; do sleep 0.5; done; vite preview --strictPort --port 5175'",
    "preview": "vite preview --port 4175"
  },
  "dependencies": {
    "vue": "^3.5.24",
    "vite-plugin-zephyr": "latest"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}