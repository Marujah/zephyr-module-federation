{
  "name": "react-remote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "tsc && vite build",
    "build:zephyr": "ENABLE_ZEPHYR=1 tsc && vite build",
    "build:watch": "MF_DEV=1 vite build --watch",
    "preview:mf": "sh -c 'while [ ! -f dist/assets/remoteEntry.js ]; do sleep 0.5; done; MF_DEV=1 vite preview --strictPort --port 5174'",
    "preview": "vite preview --port 4174"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite-plugin-zephyr": "latest"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-inspect": "^11.3.3"
  }
}
